{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dictto",
  "version": "0.2.0",
  "identifier": "com.dictto.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dictto Settings",
        "width": 700,
        "height": 500,
        "visible": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3RkQ4RTYwQzMzNTdFOUMKUldTY2ZqWERZSTc5RjFGY1VaM2psVms5UmtZS3htdE9nQjVUTkQzakhYa2hScnRpNFNKZmlkOUoK",
      "endpoints": [
        "https://github.com/dictto-app/dictto/releases/latest/download/latest.json"
      ]
    }
  }
}
